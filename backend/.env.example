# Local Postgres (omit DATABASE_URL)
DB_PORT=5432
DB_NAME=telemetry
DB_USER=postgres
DB_PASSWORD=postgres
# Production: full URL from your host (Railway, Neon, etc.)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
OWEN_DEVICE_ID=628583
OWEN_POLL_INTERVAL_SECONDS=60
# Optional: comma-separated browser origins (default includes http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
